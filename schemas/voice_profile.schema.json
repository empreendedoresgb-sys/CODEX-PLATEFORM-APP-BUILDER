{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Voice Profile Schema",
  "description": "Schema definition for voice profile configuration",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the voice profile"
    },
    "name": {
      "type": "string",
      "description": "Name of the voice profile"
    },
    "language": {
      "type": "string",
      "description": "Language code for the voice profile"
    },
    "pitch": {
      "type": "number",
      "description": "Pitch level for the voice",
      "minimum": 0.5,
      "maximum": 2.0
    },
    "rate": {
      "type": "number",
      "description": "Speech rate",
      "minimum": 0.5,
      "maximum": 2.0
    },
    "volume": {
      "type": "number",
      "description": "Volume level",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["id", "name", "language"]
}